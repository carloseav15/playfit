{
  "name": "playfit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -w packages/core && npm run build -w apps/web",
    "preview": "npm run start -w apps/web",
    "check": "npm run typecheck && npm run lint && npm test && npm run build",
    "check:ci": "npm run check && npm audit --audit-level=moderate",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e -w apps/web",
    "validate:migrations": "bash scripts/validate-migrations.sh",
    "check:covers": "node scripts/check-cover-integrity.mjs",
    "igdb:mirror": "node scripts/sync-igdb-mirror.mjs",
    "igdb:mirror:backup": "node scripts/backup-schema.mjs --schema igdb_raw",
    "igdb:mirror:restore": "node scripts/restore-schema.mjs --schema igdb_raw",
    "catalog:backup": "node scripts/backup-schema.mjs --schema games_library",
    "catalog:restore": "node scripts/restore-schema.mjs --schema games_library",
    "catalog:import-external": "bash scripts/import-external-catalog-data.sh",
    "catalog:import-review-sentiment": "bash scripts/import-metacritic-review-sentiment.sh",
    "catalog:report-external": "bash scripts/export-external-catalog-match-report.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "cheerio": "^1.2.0",
    "typescript": "^5.9.0"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
