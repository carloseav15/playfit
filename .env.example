# Supabase — replace with your project values when deploying
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-publishable-key

# Public app URL — required in production so OAuth redirects never fall back to localhost
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Sentry — DSN is safe for browser runtime; auth token is build-only and secret
NEXT_PUBLIC_SENTRY_DSN=replace-with-your-sentry-dsn
SENTRY_DSN=replace-with-your-sentry-dsn
SENTRY_AUTH_TOKEN=replace-with-your-sentry-source-map-upload-token

# Server-only — keep secret, never expose to the client
SUPABASE_SERVICE_KEY=replace-with-your-service-role-or-secret-key

# RAWG API — https://rawg.io/register (free tier: 20k requests/month)
RAWG_API_KEY=replace-with-your-rawg-api-key
